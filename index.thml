<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CM Studio</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0d0d0d;
  color: #fff;
  text-align: center;
}

.container {
  padding: 30px 20px;
}

.logo {
  font-size: 28px;
  font-weight: bold;
  color: gold;
  margin-bottom: 10px;
}

.subtitle {
  font-size: 14px;
  color: #ccc;
  margin-bottom: 30px;
}

.button {
  display: block;
  width: 100%;
  max-width: 300px;
  margin: 10px auto;
  padding: 15px;
  border-radius: 30px;
  text-decoration: none;
  font-weight: bold;
  background: gold;
  color: black;
}

.button.whatsapp {
  background: #25D366;
  color: white;
}

.footer {
  margin-top: 40px;
  font-size: 12px;
  color: #777;
}
</style>
</head>

<body>

<div class="container">

<div class="logo">CM Studio</div>
<div class="subtitle">Masajes • Belleza • Relajación</div>

<a class="button whatsapp" href="https://wa.me/529988951973" target="_blank">
📲 WhatsApp (Cancún)
</a>

<a class="button whatsapp" href="https://wa.me/525529186900" target="_blank">
📲 WhatsApp (CDMX)
</a>

<a class="button">💆 Masajes Relajantes</a>
<a class="button">✨ Pestañas</a>
